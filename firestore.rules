rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net (default-deny catch-all)
    match /{document=**} {
      allow read, write: if false;
    }

    // Hardened global helpers
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { 
      return request.resource.data; 
    }
    
    function existing() { 
      return resource.data; 
    }
    
    function isSignedIn() { 
      return request.auth != null; 
    }
    
    function isEmailVerified() {
      // Allow Google Sign-In or verified email/password
      return isSignedIn() && (
        request.auth.token.email_verified == true || 
        request.auth.token.firebase.sign_in_provider == 'google.com'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == "chukwuemekadivine524@gmail.com"
      );
    }

    // Validate User Entity integrity
    function isValidUser(data) {
      return data.uid is string && data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 128 &&
             data.displayName is string && data.displayName.size() <= 128 &&
             data.role is string && (
               data.role == "Admin" || 
               data.role == "Government Analyst" || 
               data.role == "Security Analyst" || 
               data.role == "Healthcare Analyst" || 
               data.role == "Agricultural Analyst" || 
               data.role == "General User"
             ) &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    // Collection: Users
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin(); // strict privacy - avoid PII scraping of all operator profiles
      
      allow create: if isOwner(userId) && 
                      isEmailVerified() && 
                      isValidId(userId) && 
                      incoming().keys().hasAll(['uid', 'email', 'displayName', 'photoURL', 'role', 'createdAt', 'updatedAt']) &&
                      incoming().keys().size() == 7 &&
                      isValidUser(incoming()) &&
                      // Restrict initial roles: user can pick any role (Analyst, General) except Admin, unless they are bootstrapped admin or approved by admin
                      (incoming().role != "Admin" || request.auth.token.email == "chukwuemekadivine524@gmail.com" || isAdmin());

      allow update: if (isOwner(userId) || isAdmin()) &&
                      isEmailVerified() &&
                      isValidId(userId) &&
                      isValidUser(incoming()) &&
                      incoming().createdAt == existing().createdAt && 
                      incoming().uid == existing().uid &&             
                      incoming().email == existing().email &&         
                      incoming().updatedAt == request.time &&        
                      (
                        // Owners cannot elevate their own roles
                        (!incoming().diff(existing()).affectedKeys().hasAny(['role']) && isOwner(userId)) ||
                        // Only verified Admins can override roles
                        isAdmin()
                      );

      allow delete: if isAdmin();
    }

    // Collection: Admins Lookup
    match /admins/{adminId} {
      allow get: if isSignedIn();
      allow write: if false; // bootstrapped via backend or Google email lookup in isAdmin()
    }
  }
}
